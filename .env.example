# Environment variables configuration

# This file contains the environment variables for the application. It is used to configure the application based on the environment it is running in (development, testing, production).
NODE_ENV=dev

# Secret key used for signing JWT tokens. In a real application, this should be a strong, unique value and should not be hardcoded in the source code. It should be stored securely, for example, in an environment variable or a secrets manager.
JWT_SECRET = "SUA_KEY_SECRETA_AQUI"

# The port on which the application will run. It defaults to 3333 if not specified.
PORT= 'Sua_PORTA_AQUI'

# Database connection URL. This should be in the format: postgres://username:password@host:port/database?schema=schema_name
DATABASE_URL="postgres://username:password@host:port/database?schema=schema_name"